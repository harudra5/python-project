   "source": [
    "# hybrid inharitance (multiple + hierarchical)"
   ]
  },
  {
   "cell_type": "raw",
   "id": "1ac423ca-a867-48d8-a3f2-ad4fc9edb92e",
   "metadata": {},
   "source": [
    "                 +----------------+\n",
    "                 |     Person     |  <- Base Class\n",
    "                 +----------------+\n",
    "                 | - name         |\n",
    "                 | - age          |\n",
    "                 +----------------+\n",
    "                 | +basic_info()  |\n",
    "                 +----------------+\n",
    "                  /             \\\n",
    "                 /               \\\n",
    "       +----------------+    +----------------+\n",
    "       |    Patient     |    |     Doctor     |\n",
    "       +----------------+    +----------------+\n",
    "       | - __patient_id |    | - doctor_id    |\n",
    "       | - gender       |    | - specialization|\n",
    "       +----------------+    +----------------+\n",
    "       | +get_id()      |    | +get_id()      |\n",
    "       | +to_dict()     |    | +to_dict()     |\n",
    "       +----------------+    +----------------+\n",
    "                 \\                  /\n",
    "                  \\                /\n",
    "                   \\              /\n",
    "                 +----------------+\n",
    "                 |  Appointment   |\n",
    "                 +----------------+\n",
    "                 | - patient_id   |\n",
    "                 | - doctor_id    |\n",
    "                 | - date         |\n",
    "                 +----------------+\n",
    "                 | +to_dict()     |\n",
    "                 +----------------+\n",
    "                          |\n",
    "                          |\n",
    "                 +----------------+\n",
    "                 |      Bill      |\n",
    "                 +----------------+\n",
    "                 | - patient_id   |\n",
    "                 | - days_admitted|\n",
    "                 | +CONSULTATION_FEE |\n",
    "                 | +ROOM_CHARGE_PER_DAY|\n",
    "                 +----------------+\n",
    "                 | +calculate_total_bill()|\n",
    "                 | +generate_bill()       |\n",
    "                 +----------------+\n",
    "                          |\n",
    "                          |\n",
    "                 +----------------+\n",
    "                 |    Hospital    |\n",
    "                 +----------------+\n",
    "                 | - patients     |\n",
    "                 | - doctors      |\n",
    "                 | - appointments |\n",
    "                 | - bills        |\n",
    "                 +----------------+\n",
    "                 | +add_patient() |\n",
    "                 | +add_doctor()  |\n",
    "                 | +book_appointment()|\n",
    "                 | +generate_bill()   |\n",
    "                 | +view_...()        |\n",
    "                 +----------------+"
   ]
  },
